# Copy this file to `.env` and fill in a key. `.env` is gitignored — it never uploads.

# Which model provider to use: "gemini" (free tier) or "claude" (paid).
LLM_PROVIDER=gemini

# Free Gemini key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Paid Anthropic key — get one at https://console.anthropic.com (only needed if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
