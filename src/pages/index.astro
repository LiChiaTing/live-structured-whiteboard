---
import Whiteboard from "../components/Whiteboard.jsx";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Live Structured Whiteboard</title>
  </head>
  <body class="h-full">
    <!--
      client:only="react" — Excalidraw renders only in the browser, not on the server.
      The whiteboard needs a container with height to be visible (h-screen fills the viewport).
    -->
    <main class="h-screen w-screen">
      <Whiteboard client:only="react" />
    </main>
  </body>
</html>
